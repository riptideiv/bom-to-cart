{
  "manifest_version": 3,
  "name": "BOM-to-Cart",
  "version": "0.1.0",
  "description": "AI-powered BOM purchasing assistant — parse, price, optimize",
  "permissions": ["storage", "activeTab", "scripting", "notifications", "sidePanel"],
  "host_permissions": [
    "https://octopart.com/*",
    "https://www.temu.com/*",
    "https://openrouter.ai/*",
    "http://127.0.0.1:8666/*"
  ],
  "action": {
    "default_title": "BOM-to-Cart — 点击打开侧边栏",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://octopart.com/*"],
      "js": ["content/captcha-watcher.js", "content/octopart.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.temu.com/*"],
      "js": ["content/temu.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html"
}
