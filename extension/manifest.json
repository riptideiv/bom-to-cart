{
  "manifest_version": 3,
  "name": "BOM-to-Cart",
  "version": "0.1.0",
  "description": "AI-powered BOM purchasing assistant — parse, price, optimize",
  "permissions": ["storage", "activeTab", "scripting", "notifications"],
  "host_permissions": [
    "https://octopart.com/*",
    "https://openrouter.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BOM-to-Cart",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://octopart.com/*"],
      "js": ["content/captcha-watcher.js", "content/octopart.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html"
}
